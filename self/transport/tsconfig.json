{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "jsx": "react-jsx",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "baseUrl": ".",
    "paths": {
      "@nous/shared": ["../shared/src/index.ts"],
      "@nous/shared-server": ["../apps/shared-server/src/index.ts"],
      "@nous/subcortex-apps": ["../subcortex/apps/src/index.ts"],
      "@nous/autonomic-config": ["../autonomic/config/src/index.ts"],
      "@nous/autonomic-runtime": ["../autonomic/runtime/src/index.ts"],
      "@nous/autonomic-storage": ["../autonomic/storage/src/index.ts"],
      "@nous/autonomic-embeddings": ["../autonomic/embeddings/src/index.ts"],
      "@nous/autonomic-credentials": ["../autonomic/credentials/src/index.ts"],
      "@nous/autonomic-health": ["../autonomic/health/src/index.ts"],
      "@nous/memory-access": ["../memory/access/src/index.ts"],
      "@nous/memory-mwc": ["../memory/mwc/src/index.ts"],
      "@nous/memory-stm": ["../memory/stm/src/index.ts"],
      "@nous/memory-ltm": ["../memory/ltm/src/index.ts"],
      "@nous/memory-knowledge-index": ["../memory/knowledge-index/src/index.ts"],
      "@nous/memory-distillation": ["../memory/distillation/src/index.ts"],
      "@nous/cortex-core": ["../cortex/core/src/index.ts"],
      "@nous/cortex-pfc": ["../cortex/pfc/src/index.ts"],
      "@nous/subcortex-scheduler": ["../subcortex/scheduler/src/index.ts"],
      "@nous/subcortex-projects": ["../subcortex/projects/src/index.ts"],
      "@nous/subcortex-artifacts": ["../subcortex/artifacts/src/index.ts"],
      "@nous/subcortex-escalation": ["../subcortex/escalation/src/index.ts"],
      "@nous/subcortex-router": ["../subcortex/router/src/index.ts"],
      "@nous/subcortex-providers": ["../subcortex/providers/src/index.ts"],
      "@nous/subcortex-communication-gateway": ["../subcortex/communication-gateway/src/index.ts"],
      "@nous/subcortex-endpoint-trust": ["../subcortex/endpoint-trust/src/index.ts"],
      "@nous/subcortex-workflows": ["../subcortex/workflows/src/index.ts"],
      "@nous/subcortex-voice-control": ["../subcortex/voice-control/src/index.ts"],
      "@nous/subcortex-public-mcp": ["../subcortex/public-mcp/src/index.ts"],
      "@nous/subcortex-registry": ["../subcortex/registry/src/index.ts"],
      "@nous/subcortex-nudges": ["../subcortex/nudges/src/index.ts"],
      "@nous/subcortex-witnessd": ["../subcortex/witnessd/src/index.ts"],
      "@nous/subcortex-tools": ["../subcortex/tools/src/index.ts"],
      "@nous/subcortex-opctl": ["../subcortex/opctl/src/index.ts"],
      "@nous/subcortex-mao": ["../subcortex/mao/src/index.ts"],
      "@nous/subcortex-coding-agents": ["../subcortex/coding-agents/src/index.ts"],
      "@nous/subcortex-gtm": ["../subcortex/gtm/src/index.ts"]
    }
  },
  "include": ["src/**/*.ts", "src/**/*.tsx"],
  "exclude": ["node_modules"]
}
