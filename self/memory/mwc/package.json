{
  "name": "@nous/memory-mwc",
  "version": "0.0.1",
  "private": true,
  "description": "MemoryWriteCandidate pipeline for Nous-OSS — create, evaluate, persist, export, delete",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc --build",
    "typecheck": "pnpm --filter @nous/memory-ltm build && tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@nous/shared": "workspace:*",
    "@nous/autonomic-embeddings": "workspace:*",
    "@nous/memory-ltm": "workspace:*",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@nous/autonomic-storage": "workspace:*",
    "@nous/memory-access": "workspace:*",
    "@nous/memory-stm": "workspace:*"
  }
}
