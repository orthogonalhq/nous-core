{
  "extends": "../../../tsconfig.json",
  "compilerOptions": {
    "rootDir": "src",
    "outDir": "dist",
    "composite": true,
    "paths": {
      "@nous/shared": ["../../shared/src/index.ts"],
      "@nous/autonomic-storage": ["../../autonomic/storage/src/index.ts"],
      "@nous/autonomic-embeddings": ["../../autonomic/embeddings/src/index.ts"],
      "@nous/memory-stubs": ["../stubs/src/index.ts"]
    }
  },
  "include": ["src"],
  "exclude": ["src/**/__tests__/**"],
  "references": [
    { "path": "../../shared" },
    { "path": "../../autonomic/storage" },
    { "path": "../../autonomic/embeddings" },
    { "path": "../stubs" }
  ]
}
