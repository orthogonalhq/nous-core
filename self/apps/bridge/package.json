{
  "name": "@nous/bridge",
  "version": "0.0.1",
  "private": true,
  "description": "Nous-OSS communication bridge app for approved messenger adapters",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc --build",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --config vitest.config.ts",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@nous/shared": "workspace:*",
    "@nous/subcortex-communication-gateway": "workspace:*"
  },
  "devDependencies": {
    "typescript": "^5",
    "vitest": "^4.0.18"
  }
}
