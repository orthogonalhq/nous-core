{
  "extends": "../../../tsconfig.json",
  "compilerOptions": {
    "rootDir": "src",
    "outDir": "dist",
    "composite": true,
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "lib": ["ES2022"],
    "noEmit": false,
    "paths": {
      "@nous/shared": ["../../shared/src/index.ts"],
      "@nous/subcortex-communication-gateway": ["../../subcortex/communication-gateway/src/index.ts"]
    }
  },
  "include": ["src"],
  "exclude": ["src/**/__tests__/**", "node_modules"],
  "references": [
    { "path": "../../shared" },
    { "path": "../../subcortex/communication-gateway" }
  ]
}
