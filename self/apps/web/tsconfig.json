{
  "compilerOptions": {
    "target": "ES2017",
    "lib": [
      "dom",
      "dom.iterable",
      "ES2022"
    ],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "ESNext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "preserve",
    "incremental": true,
    "plugins": [
      {
        "name": "next"
      }
    ],
    "paths": {
      "@/*": [
        "./*"
      ],
      "@nous/shared": [
        "../../shared/src/index.ts"
      ],
      "@nous/autonomic-storage": [
        "../../autonomic/storage/src/index.ts"
      ],
      "@nous/autonomic-embeddings": [
        "../../autonomic/embeddings/src/index.ts"
      ],
      "@nous/memory-access": [
        "../../memory/access/src/index.ts"
      ],
      "@nous/memory-mwc": [
        "../../memory/mwc/src/index.ts"
      ],
      "@nous/memory-ltm": [
        "../../memory/ltm/src/index.ts"
      ],
      "@nous/memory-knowledge-index": [
        "../../memory/knowledge-index/src/index.ts"
      ],
      "@nous/memory-distillation": [
        "../../memory/distillation/src/index.ts"
      ],
      "@nous/cortex-core": [
        "../../cortex/core/src/index.ts"
      ],
      "@nous/cortex-pfc": [
        "../../cortex/pfc/src/index.ts"
      ],
      "@nous/subcortex-scheduler": [
        "../../subcortex/scheduler/src/index.ts"
      ],
      "@nous/subcortex-escalation": [
        "../../subcortex/escalation/src/index.ts"
      ],
      "@nous/subcortex-communication-gateway": [
        "../../subcortex/communication-gateway/src/index.ts"
      ],
      "@nous/subcortex-endpoint-trust": [
        "../../subcortex/endpoint-trust/src/index.ts"
      ],
      "@nous/subcortex-voice-control": [
        "../../subcortex/voice-control/src/index.ts"
      ],
      "@nous/subcortex-registry": [
        "../../subcortex/registry/src/index.ts"
      ],
      "@nous/subcortex-nudges": [
        "../../subcortex/nudges/src/index.ts"
      ],
      "@nous/subcortex-witnessd": [
        "../../subcortex/witnessd/src/index.ts"
      ],
      "@nous/subcortex-tools": [
        "../../subcortex/tools/src/index.ts"
      ]
    }
  },
  "include": [
    "**/*.ts",
    "**/*.tsx",
    ".next-4317/types/**/*.ts",
    ".next-4319/types/**/*.ts",
    ".next/types/**/*.ts",
    "next-env.d.ts",
    ".next-4320/types/**/*.ts"
  ],
  "exclude": [
    "node_modules"
  ]
}
