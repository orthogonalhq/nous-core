# Nous data directory (default: ./data)
NOUS_DATA_DIR=./data

# Path to JSON5 config file (optional; defaults used if not set)
# NOUS_CONFIG_PATH=./config.json5

# Optional web port override (default used across project tooling: 4317)
# NOUS_WEB_PORT=4317

# Optional Next.js build/cache directory (default: .next-${NOUS_WEB_PORT})
# NOUS_NEXT_DIST_DIR=.next-4317

# Optional basic auth for network exposure (format: user:pass)
# NOUS_BASIC_AUTH=admin:secret
